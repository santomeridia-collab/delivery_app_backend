{
  "info": {
    "name": "Delivery App Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "token", "value": "" },
    { "key": "baseUrl", "value": "http://localhost:5000" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/send-otp",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"9999999999\"\n}" }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/verify-otp",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"9999999999\",\n  \"otp\": \"123456\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/users/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PATCH",
            "url": "{{baseUrl}}/api/users/profile",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Rahul Sharma\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Vendors",
      "item": [
        {
          "name": "Get All Vendors",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/vendors"
          }
        },
        {
          "name": "Register Vendor",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/vendors/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"shopName\": \"Rahul Medical Store\",\n  \"vendorType\": \"medical\",\n  \"address\": \"123 MG Road, Delhi\",\n  \"phone\": \"9999999999\",\n  \"latitude\": 28.6139,\n  \"longitude\": 77.2090\n}" }
          }
        },
        {
          "name": "Add Product",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/vendors/product",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Paracetamol 500mg\",\n  \"category\": \"medicine\",\n  \"price\": 25,\n  \"description\": \"Fever and pain relief\",\n  \"requiresPrescription\": false,\n  \"isAvailable\": true\n}" }
          }
        },
        {
          "name": "My Orders (Vendor)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/vendors/my/orders"
          }
        },
        {
          "name": "Update Order Status (Vendor)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PATCH",
            "url": "{{baseUrl}}/api/vendors/order/:id/confirmed"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get Products by Vendor",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/vendor/:vendorId"
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/:id"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/orders",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"vendorId\": \"VENDOR_ID\",\n  \"paymentType\": \"COD\",\n  \"items\": [\n    {\n      \"productId\": \"PRODUCT_ID\",\n      \"name\": \"Paracetamol 500mg\",\n      \"price\": 25,\n      \"quantity\": 2\n    }\n  ]\n}" }
          }
        },
        {
          "name": "Order History",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/orders/history"
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/orders/:id"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment Order",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/payments/create/:orderId"
          }
        },
        {
          "name": "Verify Payment",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/payments/verify",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"razorpay_order_id\": \"order_xxx\",\n  \"razorpay_payment_id\": \"pay_xxx\",\n  \"razorpay_signature\": \"signature_xxx\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Rider",
      "item": [
        {
          "name": "Available Orders",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/rider/available-orders"
          }
        },
        {
          "name": "Accept Order",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PATCH",
            "url": "{{baseUrl}}/api/rider/order/:id/accept"
          }
        },
        {
          "name": "Update Delivery Status",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PATCH",
            "url": "{{baseUrl}}/api/rider/order/:id/delivered"
          }
        },
        {
          "name": "Update Location",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "url": "{{baseUrl}}/api/rider/location",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"latitude\": 28.6139,\n  \"longitude\": 77.2090\n}" }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/dashboard"
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/users"
          }
        },
        {
          "name": "Get All Orders",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/orders"
          }
        },
        {
          "name": "Approve Vendor",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PATCH",
            "url": "{{baseUrl}}/api/admin/approve-vendor/:id"
          }
        }
      ]
    }
  ]
}
